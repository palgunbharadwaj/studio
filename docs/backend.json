
{
  "entities": {
    "Registration": {
      "title": "Registration",
      "description": "Information submitted by a participant for Prathibha Puraskahara SJSVT.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "language": {
          "type": "string",
          "enum": ["en", "kn"]
        },
        "studentName": {
          "type": "string"
        },
        "relationship": {
          "type": "string",
          "enum": ["SO", "DO"]
        },
        "fatherName": {
          "type": "string"
        },
        "motherName": {
          "type": "string"
        },
        "course": {
          "type": "string"
        },
        "board": {
          "type": "string"
        },
        "pucStream": {
          "type": "string"
        },
        "combination": {
          "type": "string"
        },
        "percentage": {
          "type": "string"
        },
        "marksObtained": {
          "type": "string"
        },
        "totalMarks": {
          "type": "string"
        },
        "cgpa": {
          "type": "string"
        },
        "yearOfPassing": {
          "type": "string"
        },
        "otherCourse": {
          "type": "string"
        },
        "photoBase64": {
          "type": "string",
          "description": "Base64 encoded student photo (JPG/JPEG)."
        },
        "marksCardBase64": {
          "type": "string",
          "description": "Base64 encoded marks card (PDF/DOC)."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["studentName", "email", "language", "course"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/registrations/{registrationId}": {
      "schema": "Registration",
      "description": "Collection of participant registrations."
    }
  }
}
